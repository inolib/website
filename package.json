{
  "name": "@inolib/website",
  "version": "0.0.0",
  "description": "INOLIB’s website",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build",
    "build:server": "vite build -c ./.config/vercel-edge/vite.config.ts",
    "cd:build": "pnpm run build",
    "ci:build": "pnpm run build",
    "ci:lint": "pnpm run lint",
    "ci:test": "pnpm run test",
    "format": "pnpm run format:prettier && pnpm run format:jsdoc && pnpm run format:jsxattribute-sort && pnpm run format:packagejson && pnpm run format:sort-imports && pnpm run format:tailwindcss",
    "format:jsdoc": "prettier --config ./.config/prettier/jsdoc/.prettierrc.cjs --write ./**/*.cjs ./**/*.ts ./**/*.tsx",
    "format:jsxattribute-sort": "prettier --config ./.config/prettier/jsxattribute-sort/.prettierrc.cjs --write ./**/*.tsx",
    "format:packagejson": "prettier --config ./.config/prettier/packagejson/.prettierrc.cjs --write ./package.json",
    "format:prettier": "prettier --write .",
    "format:sort-imports": "prettier --config ./.config/prettier/sort-imports/.prettierrc.cjs --write ./**/*.ts ./**/*.tsx",
    "format:tailwindcss": "prettier --config ./.config/prettier/tailwindcss/.prettierrc.cjs --write ./**/*.tsx",
    "lint": "pnpm run lint:eslint && pnpm run lint:tsc",
    "lint:eslint": "eslint --ext .cjs,.ts,.tsx .",
    "lint:tsc": "tsc",
    "serve:dev": "vite --mode ssr",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.1.4",
    "@builder.io/qwik-city": "^1.1.4",
    "graphql": "^16.6.0",
    "graphql-request": "^6.1.0",
    "nanoid": "^4.0.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.0.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vitest/coverage-c8": "^0.31.2",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-qwik": "^1.1.4",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "prettier-plugin-jsdoc": "^0.4.2",
    "prettier-plugin-jsxattribute-sort": "^1.0.1",
    "prettier-plugin-packagejson": "^2.4.3",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.4",
    "vite": "^4.3.9",
    "vite-node": "^0.31.2",
    "vitest": "^0.31.2"
  }
}
