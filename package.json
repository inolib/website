{
  "name": "",
  "description": "",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run lint && pnpm run build:client",
    "build:client": "vite build",
    "build:preview": "vite build --ssr ./src/entry.preview.tsx",
    "ci:build": "pnpm run build:client",
    "ci:lint": "pnpm run lint",
    "ci:test": "pnpm run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run lint:typescript && pnpm run lint:eslint",
    "lint:eslint": "eslint --ext .ts,.tsx .",
    "lint:typescript": "tsc",
    "preview": "pnpm run build && pnpm run build:preview && vite preview",
    "qwik": "qwik",
    "start": "vite --mode ssr",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@builder.io/qwik": "^0.20.1",
    "@builder.io/qwik-city": "^0.5.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.2",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^5.54.1",
    "@typescript-eslint/parser": "^5.54.1",
    "@vitest/coverage-c8": "^0.29.2",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.35.0",
    "eslint-config-prettier": "^8.7.0",
    "eslint-plugin-qwik": "^0.20.1",
    "postcss": "^8.4.21",
    "prettier": "^2.8.4",
    "tailwindcss": "^3.2.7",
    "typescript": "^4.9.5",
    "vite": "^4.1.4",
    "vitest": "^0.29.2"
  }
}
