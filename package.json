{
  "name": "",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "pnpm run lint && pnpm run build:client",
    "build:client": "vite build",
    "build:preview": "vite build --ssr ./src/entry.preview.tsx",
    "ci:build": "pnpm run build:client",
    "ci:lint": "pnpm run lint",
    "ci:test": "pnpm run test",
    "format": "prettier --write . ./**/*.prisma",
    "format:check": "prettier --check . ./**/*.prisma",
    "lint": "pnpm run lint:tsc && pnpm run lint:eslint",
    "lint:eslint": "eslint --ext .cjs,.ts,.tsx .",
    "lint:tsc": "tsc",
    "preview": "pnpm run build && pnpm run build:preview && vite preview",
    "qwik": "qwik",
    "start": "vite --mode ssr",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@builder.io/qwik": "^0.22.1",
    "@builder.io/qwik-city": "^0.6.3",
    "@ianvs/prettier-plugin-sort-imports": "^3.7.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.2",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^18.15.3",
    "@typescript-eslint/eslint-plugin": "^5.55.0",
    "@typescript-eslint/parser": "^5.55.0",
    "@vitest/coverage-c8": "^0.29.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.36.0",
    "eslint-config-prettier": "^8.7.0",
    "eslint-plugin-qwik": "^0.22.1",
    "nanoid": "^4.0.1",
    "postcss": "^8.4.21",
    "prettier": "^2.8.4",
    "prettier-plugin-jsdoc": "^0.4.2",
    "prettier-plugin-packagejson": "^2.4.3",
    "prettier-plugin-prisma": "^4.10.0",
    "prettier-plugin-tailwindcss": "^0.2.5",
    "prisma": "^4.11.0",
    "tailwindcss": "^3.2.7",
    "typescript": "^5.0.2",
    "vite": "^4.2.0",
    "vitest": "^0.29.3",
    "zod": "^3.21.4"
  }
}
